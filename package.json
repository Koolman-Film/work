{
  "name": "koolman-work",
  "version": "0.1.0",
  "private": true,
  "description": "Koolman Work — internal HR system, Next.js 16 + Supabase + LINE LIFF",
  "type": "module",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && (test -n \"$DIRECT_URL\" && prisma migrate deploy || echo '⚠ DIRECT_URL not set — skipping prisma migrate deploy. Set DIRECT_URL on Vercel to enable auto-migrate (must point at port 5432, not pgbouncer 6543).') && next build",
    "start": "next start",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "dotenv -e .env.local -- playwright test",
    "db:generate": "prisma generate",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "db:deploy": "dotenv -e .env.local -- prisma migrate deploy",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "db:seed": "dotenv -e .env.local -- tsx prisma/seed.ts",
    "db:reset": "dotenv -e .env.local -- prisma migrate reset --skip-seed",
    "prepare": "simple-git-hooks",
    "postinstall": "prisma generate"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,json}": "biome check --write --no-errors-on-unmatched"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@line/bot-sdk": "^11.0.0",
    "@line/liff": "^2.27.0",
    "@prisma/client": "^6.0.0",
    "@sentry/nextjs": "^9.0.0",
    "@supabase/ssr": "^0.5.0",
    "@supabase/supabase-js": "^2.45.4",
    "@tanstack/react-query": "^5.59.0",
    "@vercel/analytics": "^1.4.0",
    "@vercel/speed-insights": "^1.1.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "decimal.js": "^10.4.3",
    "inngest": "^4.4.0",
    "jose": "^6.2.3",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.16.0",
    "next": "^16.0.0",
    "next-intl": "^4.0.0",
    "pino": "^9.5.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.53.0",
    "server-only": "^0.0.1",
    "tailwind-merge": "^2.5.0",
    "zod": "^4.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@playwright/test": "^1.50.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^24.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "dotenv-cli": "^11.0.0",
    "lint-staged": "^17.0.5",
    "pino-pretty": "^11.0.0",
    "prisma": "^6.0.0",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.0",
    "vitest": "^3.0.0"
  }
}
