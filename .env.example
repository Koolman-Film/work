# Koolman HR — environment variable template
#
# Copy to .env.local and fill in real values. .env.local is gitignored.
# For local dev convenience, real values are also kept in docs/v2/credentials.local.md (gitignored).

# ─── Supabase ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_DB_PASSWORD=
DATABASE_URL=
DATABASE_POOLER_URL=

# ─── LINE ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_LIFF_ID=
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_MESSAGING_CHANNEL_ACCESS_TOKEN=

# ─── Sentry (free tier) ────────────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# ─── Inngest (free tier) ───────────────────────────────────────────────────
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ─── Runtime ───────────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
