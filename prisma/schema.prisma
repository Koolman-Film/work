// Koolman Work — Prisma schema
// Source of truth for the public-schema data model.
// Matches docs/v2/architecture.md §3 model-for-model. RLS policies, triggers,
// and functions live in Supabase migrations (not yet authored — defensive
// backstop only per decision #1, since Prisma uses service-role and bypasses RLS).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // For production: also set DATABASE_POOLER_URL (Supavisor) and switch `url`
  // to it; keep `directUrl` pointing at the direct connection for migrations.
  // For local dev a single DATABASE_URL works for both.
}

// ─── Enums ─────────────────────────────────────────────────────────────────

enum Role {
  Employee
  Admin
  Owner
}

enum AttSource {
  Liff
  Excel
  Both
  Manual
}

enum AttType {
  CheckIn
  CheckOut
  Absent
  Late
  EarlyLeave
  OnLeave
}

enum CheckInStatus {
  Confirmed
  Disputed
  Rejected
}

enum SalaryType {
  Monthly
  Daily
  Hourly
}

enum EmpStatus {
  Probation
  Active
  Archived
}

enum LeaveStatus {
  Pending
  Approved
  Rejected
  Cancelled
}

enum AdvanceStatus {
  Pending
  Approved
  Rejected
  Cancelled
}

enum PayrollStatus {
  Draft
  Published
  Locked
}

enum NotifChannel {
  LineMessage
  InAppBell
}

// ─── Identity & roles ──────────────────────────────────────────────────────

/// One row per humans-with-app-access. Mirrors the Supabase auth.users row
/// for each role; Employees get their authUserId populated lazily after their
/// first LINE sign-in via signInWithIdToken (W3 pairing flow).
model User {
  id         String    @id @default(uuid()) @db.Uuid
  authUserId String?   @unique @db.Uuid // FK to auth.users.id (Supabase-managed; no DB constraint)
  email      String?   @unique // Admin / Owner only
  lineUserId String?   @unique // Employee only — set after LIFF link
  role       Role
  /// Preferred UI language (BCP 47 — 'th', 'en', 'my', 'lo', 'zh-CN').
  /// NULL until the user explicitly picks a language. When non-null,
  /// overrides the NEXT_LOCALE cookie on next login so the preference
  /// follows the user across devices. See src/lib/i18n/config.ts.
  locale     String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?
  employee   Employee?

  notifications Notification[]
}

// ─── Organization ──────────────────────────────────────────────────────────

model Department {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @unique
  description String?
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  employees   Employee[]
}

/// "แยกพนักงาน 2 กลุ่ม เพื่อการลงบัญชี" per requirement.docx —
/// company-expense group vs paid-on-behalf/refundable group. PEAK CSV export
/// in Phase 3 splits by this.
model AccountingGroup {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @unique
  peakCode    String?   @unique // PEAK chart-of-accounts code for export grouping
  description String?
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  employees   Employee[]
}

model Branch {
  id               String    @id @default(uuid()) @db.Uuid
  name             String    @unique
  address          String?
  // Null lat/lng = no geofence enforcement on LIFF check-in.
  latitude         Decimal?  @db.Decimal(10, 7)
  longitude        Decimal?  @db.Decimal(10, 7)
  radiusMeters     Int       @default(150)
  requireSelfie    Boolean   @default(false)
  /// When true, LIFF check-ins outside the geofence (or with bad GPS
  /// accuracy / impossible-travel) are marked `Disputed`. When false,
  /// the geofence is informational only — GPS is still recorded for
  /// the admin live board but doesn't gate the check-in.
  /// Default false: a fresh branch is GPS-optional until admin opts in.
  /// Existing branches are also set to false by migration 0005.
  requireGps       Boolean   @default(false)
  /// When true, the LIFF widget prompts employees to tap "เช็คเอาท์" after
  /// their work day; when false, the check-in flow finishes at "เสร็จสิ้น"
  /// and the prompt disappears (employees can still tap an optional
  /// check-out link if they want to log their exit time). Independent of
  /// the `attendance-force-checkout-eod` cron, which still auto-closes any
  /// row without clockOutAt at 22:00 BKK regardless of branch policy.
  /// Default false; existing branches set to false by migration 0006.
  requireCheckOut  Boolean   @default(false)
  attendanceSource AttSource @default(Liff)
  archivedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  employees           Employee[]   @relation("HomeBranch")
  attendanceCheckIns  Attendance[] @relation("CheckInBranch")
}

/// A named work-schedule template — different employees / roles can be
/// assigned different schedules (e.g., "Office Mon-Fri", "Retail Mon-Sat").
/// Per-day times live in WorkScheduleDay; a missing row for a given
/// weekday means that day is non-working (closed).
model WorkSchedule {
  id               String            @id @default(uuid()) @db.Uuid
  name             String
  /// Minutes after the day's startTime before a check-in is flagged as
  /// "Late" by attendance-late-check. Applies uniformly to every day.
  lateToleranceMin Int               @default(15)
  archivedAt       DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  days             WorkScheduleDay[]
  employees        Employee[]
}

/// One row per working weekday for a given WorkSchedule. Days that
/// aren't represented are non-working (closed). dayOfWeek follows JS
/// `Date.getDay()` semantics: 0=Sunday, 1=Monday, ..., 6=Saturday.
///
/// Why a separate table (not a JSON column on WorkSchedule):
///   - DB-enforced uniqueness — can't accidentally create two Mondays
///   - Cheap to query "which schedules include Saturday"
///   - onDelete: Cascade — dropping a schedule cleans its days too
model WorkScheduleDay {
  id             String       @id @default(uuid()) @db.Uuid
  workScheduleId String       @db.Uuid
  workSchedule   WorkSchedule @relation(fields: [workScheduleId], references: [id], onDelete: Cascade)
  /// 0=Sun, 1=Mon, ..., 6=Sat (matches Date.getDay()).
  dayOfWeek      Int
  /// "HH:MM" 24-hour. App-validated; stored as text for simplicity.
  startTime      String
  endTime        String

  @@unique([workScheduleId, dayOfWeek])
  @@index([workScheduleId])
}

// ─── Employee ──────────────────────────────────────────────────────────────

model Employee {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @unique @db.Uuid
  user              User     @relation(fields: [userId], references: [id], onDelete: Restrict)

  firstName         String
  lastName          String
  nickname          String?

  // ─── Employee-managed contact fields (Sprint 2, /liff/profile) ──────────
  // All optional — employees self-service via /liff/profile after pairing.
  // Admin can also edit via /admin/employees/[id]/edit (Phase-2 work).
  // `personalEmail` is distinct from `User.email` (which is admin/owner auth).
  phone             String?
  personalEmail     String?
  address           String?
  emergencyContact  String?

  branchId          String   @db.Uuid
  branch            Branch   @relation("HomeBranch", fields: [branchId], references: [id], onDelete: Restrict)
  /// Multi-branch employees (e.g., rotating installers). Includes home branchId.
  assignedBranchIds String[] @default([])

  departmentId      String?  @db.Uuid
  department        Department? @relation(fields: [departmentId], references: [id], onDelete: Restrict)

  accountingGroupId String?  @db.Uuid
  accountingGroup   AccountingGroup? @relation(fields: [accountingGroupId], references: [id], onDelete: Restrict)

  workScheduleId    String?  @db.Uuid
  workSchedule      WorkSchedule? @relation(fields: [workScheduleId], references: [id], onDelete: Restrict)

  salaryType        SalaryType
  baseSalary        Decimal  @db.Decimal(12, 2)
  status            EmpStatus
  canCheckIn        Boolean  @default(true)
  hiredAt           DateTime @db.Date
  archivedAt        DateTime?

  // Single-use pairing JWT for LINE link; nulled after consumption.
  inviteToken       String?  @unique
  inviteExpiresAt   DateTime?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  attendances         Attendance[]
  leaveRequests       LeaveRequest[]
  cashAdvances        CashAdvance[]
  payrolls            Payroll[]
  recurringDeductions RecurringDeduction[]

  @@index([branchId])
  @@index([departmentId])
  @@index([status])
}

// ─── Attendance ────────────────────────────────────────────────────────────

model Attendance {
  id                String    @id @default(uuid()) @db.Uuid
  employeeId        String    @db.Uuid
  employee          Employee  @relation(fields: [employeeId], references: [id], onDelete: Restrict)

  date              DateTime  @db.Date
  type              AttType
  source            AttSource

  /// Duration per requirement.docx — e.g., 30 (minutes late), 480 (1-day leave).
  durationMinutes   Int?

  // LIFF check-in/out evidence
  clockInAt         DateTime?
  clockOutAt        DateTime?
  checkInLat        Decimal?  @db.Decimal(10, 7)
  checkInLng        Decimal?  @db.Decimal(10, 7)
  checkInBranchId   String?   @db.Uuid
  checkInBranch     Branch?   @relation("CheckInBranch", fields: [checkInBranchId], references: [id], onDelete: SetNull)
  checkInSelfieUrl  String?
  checkInStatus     CheckInStatus?
  disputeReason     String?

  /// When type=OnLeave, the LeaveRequest that produced these auto-rows.
  leaveRequestId    String?   @db.Uuid
  leaveRequest      LeaveRequest? @relation(fields: [leaveRequestId], references: [id], onDelete: SetNull)

  deductAmount      Decimal?  @db.Decimal(12, 2)
  isOverridden      Boolean   @default(false)
  overrideNote      String?

  createdAt         DateTime  @default(now())
  /// User.id of whoever recorded this — employee for LIFF, admin for manual,
  /// system for cron (e.g., force-checkout-eod). Not a FK; users are soft-deleted.
  createdById       String    @db.Uuid

  @@unique([employeeId, date, type])
  @@index([date])
  @@index([employeeId, date])
  @@index([checkInStatus])
}

// ─── Leave & Cash Advance ──────────────────────────────────────────────────

model LeaveType {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @unique // "ลาป่วย", "ลากิจ", "ลาพักร้อน"
  isPaid      Boolean   @default(true)
  annualQuota Int?      // null = unlimited (e.g., unpaid leave)
  archivedAt  DateTime?
  requests    LeaveRequest[]
}

model LeaveRequest {
  id            String    @id @default(uuid()) @db.Uuid
  employeeId    String    @db.Uuid
  employee      Employee  @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  leaveTypeId   String    @db.Uuid
  leaveType     LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Restrict)
  startDate     DateTime  @db.Date
  endDate       DateTime  @db.Date
  reason        String
  attachmentUrl String?   // medical certificate / supporting doc
  status        LeaveStatus
  reviewedById  String?   @db.Uuid
  reviewedAt    DateTime?
  reviewNote    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  attendances   Attendance[]

  @@index([employeeId, status])
  @@index([status])
}

model CashAdvance {
  id                  String    @id @default(uuid()) @db.Uuid
  employeeId          String    @db.Uuid
  employee            Employee  @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  amount              Decimal   @db.Decimal(12, 2)
  requestedAt         DateTime  @default(now())
  status              AdvanceStatus
  approvedById        String?   @db.Uuid
  approvedAt          DateTime?
  receiptUrl          String?
  /// Set by Phase 2 payroll publish; once true, this advance is consumed.
  isDeducted          Boolean   @default(false)
  deductedInPayrollId String?   @db.Uuid
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([employeeId, status])
  @@index([status])
  @@index([isDeducted])
}

// ─── Payroll (Phase 2) ─────────────────────────────────────────────────────

/// Source of Payroll.deductDebt — auto-decrements monthsRemaining each
/// publish until 0, then auto-ends.
model RecurringDeduction {
  id              String    @id @default(uuid()) @db.Uuid
  employeeId      String    @db.Uuid
  employee        Employee  @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  reason          String    // "เงินกู้บริษัท", "ผ่อนอุปกรณ์"
  monthlyAmount   Decimal   @db.Decimal(12, 2)
  monthsRemaining Int
  startedAt       DateTime  @default(now())
  endedAt         DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([employeeId, endedAt])
}

model Payroll {
  id               String        @id @default(uuid()) @db.Uuid
  employeeId       String        @db.Uuid
  employee         Employee      @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  month            String        // "2026-04" YYYY-MM

  incomeBase       Decimal       @db.Decimal(12, 2)
  incomeOther      Decimal       @db.Decimal(12, 2) @default(0)

  deductSso        Decimal       @db.Decimal(12, 2) @default(0)
  deductAdvance    Decimal       @db.Decimal(12, 2) @default(0)
  deductAttendance Decimal       @db.Decimal(12, 2) @default(0)
  /// Per requirement.docx §4 Deduct_Debt
  deductDebt       Decimal       @db.Decimal(12, 2) @default(0)

  netPay           Decimal       @db.Decimal(12, 2)

  status           PayrollStatus
  publishedAt      DateTime?
  pdfUrl           String?

  revisionOfId     String?       @db.Uuid
  revisionOf       Payroll?      @relation("Revision", fields: [revisionOfId], references: [id], onDelete: SetNull)
  revisions        Payroll[]     @relation("Revision")

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@unique([employeeId, month])
  @@index([month])
  @@index([status])
}

/// Singleton configuration for the payroll calc engine (Phase 2).
/// The model allows multiple rows but app code always reads the first
/// via `findFirst()`. Seed creates one row; admin edits via the future
/// /admin/settings/payroll-config page (Phase 3).
model PayrollConfig {
  id        String   @id @default(uuid()) @db.Uuid
  /// Social Security rate, e.g. 0.0500 = 5%.
  ssoRate   Decimal  @db.Decimal(5, 4)
  /// Cap on the base-salary value used for SSO calculation (₿15,000 per Thai law).
  ssoSalaryCap Decimal @db.Decimal(12, 2)
  /// Cap on the monthly SSO deduction itself (₿750 per Thai law).
  ssoAmountCap Decimal @db.Decimal(12, 2)
  /// Overtime multiplier (1.5 = OT pays 1.5× regular).
  otMultiplier Decimal @db.Decimal(3, 2)
  /// Day of month payroll cut-off — e.g., 25 means "calculate for the
  /// 26th of prior month through the 25th of this month".
  cutoffDay    Int      @default(25)
  /// Flat deduction per "Absent" day. Phase-2 polish may auto-derive from baseSalary/30.
  absentDeductionPerDay Decimal @db.Decimal(12, 2)
  /// Flat deduction per "Late" attendance row (count-based, ignores duration).
  lateDeduction         Decimal @db.Decimal(12, 2)
  /// Flat deduction per "EarlyLeave" attendance row.
  earlyLeaveDeduction   Decimal @db.Decimal(12, 2)

  updatedAt DateTime @updatedAt
}

// ─── Cross-cutting ─────────────────────────────────────────────────────────

model Holiday {
  id           String   @id @default(uuid()) @db.Uuid
  date         DateTime @db.Date @unique
  name         String   // "วันแรงงาน"
  /// True if this is a substitute day (Thai cabinet decree, or auto-shifted
  /// because the original Mon-holiday fell on Koolman's closed day).
  isSubstitute Boolean  @default(false)
  archivedAt   DateTime?
}

model Notification {
  id        String       @id @default(uuid()) @db.Uuid
  userId    String       @db.Uuid
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel   NotifChannel
  event     String       // "leave.approved", "advance.approved", "payroll.published", ...
  payload   Json
  readAt    DateTime?
  sentAt    DateTime?
  createdAt DateTime     @default(now())

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, readAt])
}

model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  /// User.id of the actor, or null for system actions / when actor deleted.
  actorId     String?  @db.Uuid
  action      String   // "employee.create", "payroll.publish", "leave.approve", ...
  entityType  String   // "Employee", "Payroll", "LeaveRequest", ...
  entityId    String   @db.Uuid
  beforeValue Json?
  afterValue  Json?
  metadata    Json?    // IP, user-agent, source location, etc.
  createdAt   DateTime @default(now())

  @@index([entityType, entityId, createdAt(sort: Desc)])
  @@index([actorId, createdAt(sort: Desc)])
  @@index([action])
}
