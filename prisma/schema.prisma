// Koolman Work — Prisma schema
// Source of truth for the public-schema data model.
// Matches docs/v2/architecture.md §3 model-for-model. RLS policies, triggers,
// and functions live in Supabase migrations (not yet authored — defensive
// backstop only per decision #1, since Prisma uses service-role and bypasses RLS).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Runtime queries — uses the Supabase pgbouncer pooler in prod
  // (port 6543, transaction pooling). Cheap and stateless, ideal for
  // Vercel Functions' short-lived connections.
  url       = env("DATABASE_URL")
  // Schema migrations — uses a direct (session-level) connection
  // because Prisma's `migrate deploy` takes advisory locks and runs
  // multi-statement transactions that pgbouncer transaction-pooling
  // breaks (the lock either fails or hangs forever, as we hit in
  // build dpl_9edoaGi93c4gSqHJvKq6oTm8RsSJ on 2026-05-28). Point
  // DIRECT_URL at port 5432 of the same DB host.
  // For local dev a single DATABASE_URL works for both — set
  // DIRECT_URL to the same value (Prisma falls back if absent).
  directUrl = env("DIRECT_URL")
}

// ─── Enums ─────────────────────────────────────────────────────────────────

/// Coarse user category — historically a column on User, dropped in
/// Phase 4.6 (the column had become a shadow-synced copy of "highest
/// active role assignment" and added no value beyond what
/// `computeTier()` derives from UserRoleAssignment at read time).
///
/// The enum survives as a TS-only type — it's still imported across
/// the codebase (requireRole's allowlist parameter, canActOnRole,
/// computeTier's return value, the tier field forwarded through
/// requirePermission). Defining it here keeps `import type { Role }
/// from '@prisma/client'` working everywhere without forcing every
/// callsite to learn a new symbol.
enum Role {
  Staff
  Admin
  Superadmin
}

enum AttSource {
  Liff
  Excel
  Both
  Manual
}

enum AttType {
  CheckIn
  CheckOut
  Absent
  Late
  EarlyLeave
  OnLeave
}

enum CheckInStatus {
  Confirmed
  Disputed
  Rejected
}

enum SalaryType {
  Monthly
  Daily
  Hourly
}

enum EmpStatus {
  Probation
  Active
  Archived
}

enum LeaveStatus {
  Pending
  Approved
  Rejected
  Cancelled
}

enum OtRateType {
  PerHourAmount
  Multiplier
}

enum OtStatus {
  Approved
  Rejected
}

enum LeaveUnit {
  FullDay
  HalfMorning
  HalfAfternoon
  Hourly
}

/// What happens when an approved leave would exceed the year's entitlement.
enum OverQuotaPolicy {
  Block // over-quota requests cannot be approved (e.g. vacation)
  DeductPay // approval allowed; the over-quota portion is salary-deducted
}

enum AdvanceStatus {
  Pending
  Approved
  Rejected
  Cancelled
}

enum PayrollStatus {
  Draft
  Published
  Locked
}

enum NotifChannel {
  LineMessage
  InAppBell
}

// ─── Identity & roles ──────────────────────────────────────────────────────

/// One row per humans-with-app-access. Mirrors the Supabase auth.users row
/// for each role; Staff users get their authUserId populated lazily after
/// their first LINE sign-in via signInWithIdToken (W3 pairing flow).
model User {
  id                       String    @id @default(uuid()) @db.Uuid
  authUserId               String?   @unique @db.Uuid // FK to auth.users.id (Supabase-managed; no DB constraint)
  email                    String?   @unique // Admin / Superadmin only
  lineUserId               String?   @unique // Set after LIFF pairing — staff (worker pair) AND admins (admin pair via lineInviteToken)
  /// Single-use admin LINE-pairing token (JWT, scope='admin-pair').
  /// Mirrors Employee.inviteToken but lives on User because admins have
  /// no Employee row. Nulled on successful pair (consume) or regenerate.
  lineInviteToken          String?   @unique
  lineInviteExpiresAt      DateTime?
  /// Effective UI language (BCP 47 — 'th','en','my','lo','zh-CN','km').
  /// Written by BOTH the worker (modal/switcher) and an admin (employee
  /// edit page). Last write wins. DB-authoritative on LIFF entry — see
  /// src/lib/i18n/liff-locale.ts. NULL until anyone sets it.
  locale                   String?
  /// When the WORKER explicitly picked a language (modal or switcher).
  /// NULL ⇒ the LIFF first-run language modal fires. Admin writes to
  /// `locale` never touch this. See src/lib/i18n/modal-trigger.ts.
  localeChosenByEmployeeAt DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  archivedAt               DateTime?
  employee                 Employee?

  notifications   Notification[]
  roleAssignments UserRoleAssignment[]
}

// ─── Granular role / permission system ─────────────────────────────────────

/// A named bundle of permissions. The catalog of permission keys lives
/// in code (`src/lib/auth/permissions.ts`) — this table just stores which
/// keys each role grants.
///
/// Three system roles ship by default (Superadmin, Admin, Staff) — see
/// migration 0009 + seed.ts. Admins can create additional custom roles
/// via the (future) admin UI; those have isSystem=false.
///
/// Superadmin uses the `isSuperadmin=true` shortcut — `canDo()` returns
/// true for any permission regardless of the `permissions[]` contents.
/// This keeps Superadmin's grant up-to-date as the permission catalog
/// grows; we never need to re-migrate the role row when adding a
/// permission key.
model RoleDefinition {
  id           String    @id @default(uuid()) @db.Uuid
  /// Stable identifier ('superadmin', 'admin', 'staff' for system
  /// roles; admin-chosen slugs for custom roles). Lowercase-kebab.
  key          String    @unique
  /// Display name shown in admin UI (localized strings live in code).
  name         String
  description  String?
  /// Permission keys this role grants. Strings from PERMISSIONS in
  /// src/lib/auth/permissions.ts. Stored as TEXT[] — small lists, no
  /// need for a join table.
  permissions  String[]  @default([])
  /// When true, grants every permission via a runtime shortcut in
  /// canDo(). Reserved for the 'superadmin' system role. Custom roles
  /// must have this false.
  isSuperadmin Boolean   @default(false)
  /// System roles are protected: can't be deleted, permissions can be
  /// edited only via migration/seed. Admin-created roles have
  /// isSystem=false and are fully mutable through the UI.
  isSystem     Boolean   @default(false)
  archivedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  assignments UserRoleAssignment[]

  @@index([archivedAt])
}

/// Assignment of a RoleDefinition to a User, optionally scoped to a
/// single Branch. `branchId = NULL` means "applies to all branches"
/// (Superadmin always uses NULL; Admin/Staff are typically per-branch).
///
/// A user can have multiple assignments — that's the design intent.
/// Example: same User holds (Staff @ Branch A) + (Admin @ Branch B).
///
/// Phase 1 records branchId but `canDo()` doesn't yet enforce it.
/// Phase 3 wires up real scope checks. See docs/v2/permissions.md.
model UserRoleAssignment {
  id        String         @id @default(uuid()) @db.Uuid
  userId    String         @db.Uuid
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId    String         @db.Uuid
  role      RoleDefinition @relation(fields: [roleId], references: [id], onDelete: Restrict)
  branchId  String?        @db.Uuid
  branch    Branch?        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())

  /// A user can't have two identical assignments. (Same role, same scope.)
  @@unique([userId, roleId, branchId])
  @@index([userId])
  @@index([roleId])
  @@index([branchId])
}

// ─── Organization ──────────────────────────────────────────────────────────

model Department {
  id          String     @id @default(uuid()) @db.Uuid
  name        String     @unique
  description String?
  archivedAt  DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  employees   Employee[]
}

/// "แยกพนักงาน 2 กลุ่ม เพื่อการลงบัญชี" per requirement.docx —
/// company-expense group vs paid-on-behalf/refundable group. PEAK CSV export
/// in Phase 3 splits by this.
model AccountingGroup {
  id          String     @id @default(uuid()) @db.Uuid
  name        String     @unique
  peakCode    String?    @unique // PEAK chart-of-accounts code for export grouping
  description String?
  archivedAt  DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  employees   Employee[]
}

/// National bank reference list (BOT-supervised). Seed-managed (no admin
/// CRUD UI) — see prisma/seed-banks-data.ts. Employees reference a bank to
/// receive salary / cash-advance transfers.
model Bank {
  id         String    @id @default(uuid()) @db.Uuid
  /// National clearing code, e.g. "004" (KBANK). Unique, stable.
  code       String    @unique
  nameTh     String
  nameEn     String
  /// Short label shown in dropdowns, e.g. "KBANK".
  shortName  String?
  /// Display ordering — common payroll banks first.
  sortOrder  Int       @default(0)
  archivedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  employees Employee[]

  @@index([archivedAt])
}

model Branch {
  id               String    @id @default(uuid()) @db.Uuid
  name             String    @unique
  address          String?
  // Null lat/lng = no geofence enforcement on LIFF check-in.
  latitude         Decimal?  @db.Decimal(10, 7)
  longitude        Decimal?  @db.Decimal(10, 7)
  radiusMeters     Int       @default(150)
  requireSelfie    Boolean   @default(false)
  /// When true, LIFF check-ins outside the geofence (or with bad GPS
  /// accuracy / impossible-travel) are marked `Disputed`. When false,
  /// the geofence is informational only — GPS is still recorded for
  /// the admin live board but doesn't gate the check-in.
  /// Default false: a fresh branch is GPS-optional until admin opts in.
  /// Existing branches are also set to false by migration 0005.
  requireGps       Boolean   @default(false)
  /// When true, the LIFF widget prompts employees to tap "เช็คเอาท์" after
  /// their work day; when false, the check-in flow finishes at "เสร็จสิ้น"
  /// and the prompt disappears (employees can still tap an optional
  /// check-out link if they want to log their exit time). Independent of
  /// the `attendance-force-checkout-eod` cron, which still auto-closes any
  /// row without clockOutAt at 22:00 BKK regardless of branch policy.
  /// Default false; existing branches set to false by migration 0006.
  requireCheckOut  Boolean   @default(false)
  attendanceSource AttSource @default(Liff)
  archivedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  employees          Employee[]           @relation("HomeBranch")
  attendanceCheckIns Attendance[]         @relation("CheckInBranch")
  roleAssignments    UserRoleAssignment[]
}

/// A named work-schedule template — different employees / roles can be
/// assigned different schedules (e.g., "Office Mon-Fri", "Retail Mon-Sat").
/// Per-day times live in WorkScheduleDay; a missing row for a given
/// weekday means that day is non-working (closed).
model WorkSchedule {
  id               String            @id @default(uuid()) @db.Uuid
  name             String
  /// Minutes after the day's startTime before a check-in is flagged as
  /// "Late" by attendance-late-check. Applies uniformly to every day.
  lateToleranceMin Int               @default(15)
  archivedAt       DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  days             WorkScheduleDay[]
  employees        Employee[]
}

/// One row per working weekday for a given WorkSchedule. Days that
/// aren't represented are non-working (closed). dayOfWeek follows JS
/// `Date.getDay()` semantics: 0=Sunday, 1=Monday, ..., 6=Saturday.
///
/// Why a separate table (not a JSON column on WorkSchedule):
///   - DB-enforced uniqueness — can't accidentally create two Mondays
///   - Cheap to query "which schedules include Saturday"
///   - onDelete: Cascade — dropping a schedule cleans its days too
model WorkScheduleDay {
  id             String       @id @default(uuid()) @db.Uuid
  workScheduleId String       @db.Uuid
  workSchedule   WorkSchedule @relation(fields: [workScheduleId], references: [id], onDelete: Cascade)
  /// 0=Sun, 1=Mon, ..., 6=Sat (matches Date.getDay()).
  dayOfWeek      Int
  /// "HH:MM" 24-hour. App-validated; stored as text for simplicity.
  startTime      String
  endTime        String

  @@unique([workScheduleId, dayOfWeek])
  @@index([workScheduleId])
}

// ─── Employee ──────────────────────────────────────────────────────────────

model Employee {
  id     String @id @default(uuid()) @db.Uuid
  userId String @unique @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  firstName String
  lastName  String
  nickname  String?

  // ─── Employee-managed contact fields (Sprint 2, /liff/profile) ──────────
  // All optional — employees self-service via /liff/profile after pairing.
  // Admin can also edit via /admin/employees/[id]/edit (Phase-2 work).
  // `personalEmail` is distinct from `User.email` (which is admin/owner auth).
  phone            String?
  personalEmail    String?
  address          String?
  emergencyContact String?

  // ─── Profile extras (admin-managed) ────────────────────────────────────
  /// Storage key within the `attendance-photos` bucket; signed at view-time.
  photoKey    String?
  dateOfBirth DateTime? @db.Date

  /// Salary / advance payout destination.
  bankId            String? @db.Uuid
  bank              Bank?   @relation(fields: [bankId], references: [id], onDelete: Restrict)
  bankAccountNumber String?
  bankAccountName   String?

  branchId          String   @db.Uuid
  branch            Branch   @relation("HomeBranch", fields: [branchId], references: [id], onDelete: Restrict)
  /// Multi-branch employees (e.g., rotating installers). Includes home branchId.
  assignedBranchIds String[] @default([])

  departmentId String?     @db.Uuid
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: Restrict)

  accountingGroupId String?          @db.Uuid
  accountingGroup   AccountingGroup? @relation(fields: [accountingGroupId], references: [id], onDelete: Restrict)

  workScheduleId String?       @db.Uuid
  workSchedule   WorkSchedule? @relation(fields: [workScheduleId], references: [id], onDelete: Restrict)

  salaryType           SalaryType
  baseSalary           Decimal     @db.Decimal(12, 2)
  // Per-employee default OT rate (overridable per OvertimeEntry).
  defaultOtRateType    OtRateType?
  defaultOtRatePerHour Decimal?    @db.Decimal(12, 2)
  defaultOtMultiplier  Decimal?    @db.Decimal(3, 2)
  /// Social security (ประกันสังคม) enrollment — when true, payroll deducts
  /// SSO from base salary per PayrollConfig (5% capped). Frozen into the
  /// Payroll row at calc time, so published slips never change retroactively.
  /// Default false: admin explicitly ticks enrolled employees.
  hasSso               Boolean     @default(false)
  status               EmpStatus
  canCheckIn           Boolean     @default(true)
  hiredAt              DateTime    @db.Date
  archivedAt           DateTime?

  // Single-use pairing JWT for LINE link; nulled after consumption.
  inviteToken     String?   @unique
  inviteExpiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attendances         Attendance[]
  leaveRequests       LeaveRequest[]
  leaveEntitlements   LeaveEntitlement[]
  overtimeEntries     OvertimeEntry[]
  cashAdvances        CashAdvance[]
  payrolls            Payroll[]
  recurringDeductions RecurringDeduction[]
  payrollAdjustments  PayrollAdjustment[]

  @@index([branchId])
  @@index([departmentId])
  @@index([status])
  @@index([bankId])
}

// ─── Attendance ────────────────────────────────────────────────────────────

model Attendance {
  id         String   @id @default(uuid()) @db.Uuid
  employeeId String   @db.Uuid
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Restrict)

  date   DateTime  @db.Date
  type   AttType
  source AttSource

  /// Duration per requirement.docx — e.g., 30 (minutes late), 480 (1-day leave).
  durationMinutes Int?

  // LIFF check-in/out evidence
  clockInAt        DateTime?
  clockOutAt       DateTime?
  checkInLat       Decimal?       @db.Decimal(10, 7)
  checkInLng       Decimal?       @db.Decimal(10, 7)
  checkInBranchId  String?        @db.Uuid
  checkInBranch    Branch?        @relation("CheckInBranch", fields: [checkInBranchId], references: [id], onDelete: SetNull)
  checkInSelfieUrl String?
  checkInStatus    CheckInStatus?
  disputeReason    String?

  /// When type=OnLeave, the LeaveRequest that produced these auto-rows.
  leaveRequestId String?       @db.Uuid
  leaveRequest   LeaveRequest? @relation(fields: [leaveRequestId], references: [id], onDelete: SetNull)

  /// OT entries surfaced from this check-in's clock-out (back-relation).
  overtimeEntries OvertimeEntry[]

  deductAmount Decimal? @db.Decimal(12, 2)
  isOverridden Boolean  @default(false)
  overrideNote String?

  deletedAt    DateTime?
  deletedById  String?   @db.Uuid
  deleteReason String?

  createdAt   DateTime @default(now())
  /// User.id of whoever recorded this — employee for LIFF, admin for manual,
  /// system for cron (e.g., force-checkout-eod). Not a FK; users are soft-deleted.
  createdById String   @db.Uuid

  // NOTE: the (employeeId, date, type) uniqueness is enforced by a PARTIAL
  // unique index `WHERE "deletedAt" IS NULL` created in migration 0014.
  // Prisma's schema DSL cannot express partial-unique, so it lives in raw
  // SQL. Do not re-add @@unique here — it would conflict with the partial index.
  @@index([date])
  @@index([employeeId, date])
  @@index([checkInStatus])
  @@index([deletedAt])
}

// ─── Leave & Cash Advance ──────────────────────────────────────────────────

model LeaveType {
  id              String             @id @default(uuid()) @db.Uuid
  name            String             @unique // "ลาป่วย", "ลากิจ", "ลาพักร้อน"
  /// Optional per-locale display names for worker-facing UI, keyed by app
  /// locale ({"en": "Personal leave", "my": "..."}). Missing/blank locales
  /// fall back to `name` (the Thai canonical name the admin UI shows).
  nameByLocale    Json?
  isPaid          Boolean            @default(true)
  annualQuota     Int? // null = unlimited (e.g., unpaid leave)
  overQuotaPolicy OverQuotaPolicy    @default(DeductPay)
  allowFullDay    Boolean            @default(true)
  allowHalfDay    Boolean            @default(false)
  allowHourly     Boolean            @default(false)
  archivedAt      DateTime?
  requests        LeaveRequest[]
  entitlements    LeaveEntitlement[]
}

/// Company-wide leave-unit configuration (singleton — read via findFirst()).
/// Defines the morning/afternoon half-day windows; the standard day length is
/// derived from them. Edited on /admin/settings/leave-config.
model LeaveConfig {
  id             String   @id @default(uuid()) @db.Uuid
  morningStart   String   @default("09:00") // "HH:MM" 24h, app-validated
  morningEnd     String   @default("12:00")
  afternoonStart String   @default("13:00")
  afternoonEnd   String   @default("17:00")
  updatedAt      DateTime @updatedAt
}

/// Per-employee, per-year leave allowance for one leave type. Seeded from
/// LeaveType.annualQuota × standardDayMinutes but individually editable for
/// onboarding. Remaining = granted + carryover + adjustment − used (used =
/// Σ chargedMinutes of approved leave that year). See spec §Phase 2.
model LeaveEntitlement {
  id                String    @id @default(uuid()) @db.Uuid
  employeeId        String    @db.Uuid
  employee          Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveTypeId       String    @db.Uuid
  leaveType         LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Restrict)
  periodYear        Int // calendar year
  grantedMinutes    Int? // null = unlimited (mirrors annualQuota = null)
  carryoverMinutes  Int       @default(0)
  adjustmentMinutes Int       @default(0) // signed; opening balance / corrections
  note              String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([employeeId, leaveTypeId, periodYear])
  @@index([employeeId, periodYear])
}

model LeaveRequest {
  id                  String       @id @default(uuid()) @db.Uuid
  employeeId          String       @db.Uuid
  employee            Employee     @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  leaveTypeId         String       @db.Uuid
  leaveType           LeaveType    @relation(fields: [leaveTypeId], references: [id], onDelete: Restrict)
  startDate           DateTime     @db.Date
  endDate             DateTime     @db.Date
  unit                LeaveUnit    @default(FullDay)
  startTime           String? // "HH:MM" — set for HalfMorning/HalfAfternoon/Hourly
  endTime             String?
  chargedMinutes      Int? // frozen at approval; the amount deducted from balance
  /// Minutes beyond the year entitlement, frozen at approval (0/null = within quota).
  overQuotaMinutes    Int?
  /// Money value of overQuotaMinutes at the employee's per-minute rate, frozen at approval.
  deductAmount        Decimal?     @db.Decimal(12, 2)
  /// Payroll row that swept this deduction (null = not yet deducted). Mirrors CashAdvance.
  deductedInPayrollId String?      @db.Uuid
  reason              String
  attachmentUrl       String? // medical certificate / supporting doc
  status              LeaveStatus
  reviewedById        String?      @db.Uuid
  reviewedAt          DateTime?
  reviewNote          String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  deletedAt           DateTime?
  deletedById         String?      @db.Uuid
  deleteReason        String?
  attendances         Attendance[]

  @@index([employeeId, status])
  @@index([status])
  @@index([deletedAt])
}

model CashAdvance {
  id                  String        @id @default(uuid()) @db.Uuid
  employeeId          String        @db.Uuid
  employee            Employee      @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  amount              Decimal       @db.Decimal(12, 2)
  requestedAt         DateTime      @default(now())
  status              AdvanceStatus
  approvedById        String?       @db.Uuid
  approvedAt          DateTime?
  receiptUrl          String?
  /// Two-step payment: set the FIRST time a transfer slip is attached
  /// after approval. receiptUrl + paidAt together mean "money sent".
  /// Slip re-upload replaces receiptUrl but never overwrites paidAt.
  paidAt              DateTime?
  /// Set by Phase 2 payroll publish; once true, this advance is consumed.
  isDeducted          Boolean       @default(false)
  deductedInPayrollId String?       @db.Uuid
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  deletedAt           DateTime?
  deletedById         String?       @db.Uuid
  deleteReason        String?

  // NOTE: "one active pending advance per employee" is enforced by a PARTIAL
  // UNIQUE index — CashAdvance_one_active_pending_key ON (employeeId) WHERE
  // status='Pending' AND deletedAt IS NULL — defined in raw SQL (migration
  // 0021). Prisma's DSL can't express partial-unique. Do NOT add a plain
  // @@unique here; it would block legitimate historical non-pending rows.
  @@index([employeeId, status])
  @@index([status])
  @@index([isDeducted])
  @@index([deletedAt])
}

// ─── Payroll (Phase 2) ─────────────────────────────────────────────────────

/// Source of Payroll.deductDebt — auto-decrements monthsRemaining each
/// publish until 0, then auto-ends.
model RecurringDeduction {
  id              String    @id @default(uuid()) @db.Uuid
  employeeId      String    @db.Uuid
  employee        Employee  @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  reason          String // "เงินกู้บริษัท", "ผ่อนอุปกรณ์"
  monthlyAmount   Decimal   @db.Decimal(12, 2)
  monthsRemaining Int
  startedAt       DateTime  @default(now())
  endedAt         DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([employeeId, endedAt])
}

enum AdjustmentKind {
  Income
  Deduction
}

/// One-off or recurring earnings/deductions (เงินเพิ่ม/เงินลด) entered by
/// admin. Applies to month M iff startMonth <= M <= (endMonth ?? ∞) —
/// lexicographic compare works for YYYY-MM. Frequency mapping:
///   one-time   → startMonth == endMonth
///   monthly    → endMonth = null (open-ended)
///   date-range → startMonth < endMonth
/// Selection-by-range is idempotent (recalc never double-applies), so no
/// sweep stamping is needed — unlike CashAdvance/LeaveRequest.
model PayrollAdjustment {
  id         String         @id @default(uuid()) @db.Uuid
  employeeId String         @db.Uuid
  employee   Employee       @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  kind       AdjustmentKind
  reason     String // "ค่าคอมมิชชั่น", "หักค่าชุดฟอร์ม", ...
  amount     Decimal        @db.Decimal(12, 2)
  startMonth String // "YYYY-MM" — first month it applies
  endMonth   String? // null = open-ended monthly
  note       String?
  deletedAt  DateTime?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([employeeId, startMonth])
  @@index([deletedAt])
}

model Payroll {
  id         String   @id @default(uuid()) @db.Uuid
  employeeId String   @db.Uuid
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  month      String // "2026-04" YYYY-MM

  incomeBase  Decimal @db.Decimal(12, 2)
  incomeOther Decimal @default(0) @db.Decimal(12, 2)

  deductSso        Decimal @default(0) @db.Decimal(12, 2)
  deductAdvance    Decimal @default(0) @db.Decimal(12, 2)
  deductAttendance Decimal @default(0) @db.Decimal(12, 2)
  deductLeave      Decimal @default(0) @db.Decimal(12, 2)
  /// Per requirement.docx §4 Deduct_Debt
  deductDebt       Decimal @default(0) @db.Decimal(12, 2)
  /// Sum of Deduction-kind PayrollAdjustments for the month (เงินลด).
  /// Income-kind adjustments land in incomeOther.
  deductOther      Decimal @default(0) @db.Decimal(12, 2)

  netPay Decimal @db.Decimal(12, 2)

  status      PayrollStatus
  publishedAt DateTime?
  pdfUrl      String?

  revisionOfId String?   @db.Uuid
  revisionOf   Payroll?  @relation("Revision", fields: [revisionOfId], references: [id], onDelete: SetNull)
  revisions    Payroll[] @relation("Revision")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, month])
  @@index([month])
  @@index([status])
}

/// One overtime record per (employee, date). computedAmount is frozen at
/// approval (snapshot of rate × hours / wage × multiplier). status=Rejected
/// is a "dismissed — not OT" marker that stops the date re-surfacing as a
/// candidate. Candidates themselves are computed live (not stored). See spec §Phase 3.
model OvertimeEntry {
  id                 String      @id @default(uuid()) @db.Uuid
  employeeId         String      @db.Uuid
  employee           Employee    @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  date               DateTime    @db.Date
  minutes            Int
  rateType           OtRateType
  ratePerHour        Decimal?    @db.Decimal(12, 2) // when PerHourAmount
  multiplier         Decimal?    @db.Decimal(3, 2) // when Multiplier
  computedAmount     Decimal     @db.Decimal(12, 2) // frozen pay at approval
  status             OtStatus
  sourceAttendanceId String?     @db.Uuid
  sourceAttendance   Attendance? @relation(fields: [sourceAttendanceId], references: [id], onDelete: SetNull)
  note               String?
  reviewedById       String?     @db.Uuid
  reviewedAt         DateTime?
  deletedAt          DateTime?
  deletedById        String?     @db.Uuid
  deleteReason       String?
  createdAt          DateTime    @default(now())
  createdById        String      @db.Uuid
  // PARTIAL unique (employeeId, date) WHERE deletedAt IS NULL — raw SQL in the
  // migration (Prisma DSL can't express partial-unique; see Attendance 0014).

  @@index([employeeId, date])
  @@index([status])
  @@index([deletedAt])
}

/// Singleton configuration for the payroll calc engine (Phase 2).
/// The model allows multiple rows but app code always reads the first
/// via `findFirst()`. Seed creates one row; admin edits via the future
/// /admin/settings/payroll-config page (Phase 3).
model PayrollConfig {
  id                     String  @id @default(uuid()) @db.Uuid
  /// Social Security rate, e.g. 0.0500 = 5%.
  ssoRate                Decimal @db.Decimal(5, 4)
  /// Cap on the base-salary value used for SSO calculation (₿15,000 per Thai law).
  ssoSalaryCap           Decimal @db.Decimal(12, 2)
  /// Cap on the monthly SSO deduction itself (₿750 per Thai law).
  ssoAmountCap           Decimal @db.Decimal(12, 2)
  /// Overtime multiplier (1.5 = OT pays 1.5× regular).
  otMultiplier           Decimal @db.Decimal(3, 2)
  /// Days/month used to derive an hourly wage from a monthly salary for OT
  /// multiplier-mode pricing (Thai convention ÷30).
  workingDaysPerMonth    Int     @default(30)
  /// Clock-out must beat the scheduled end by at least this many minutes to
  /// surface as an OT candidate.
  otThresholdMinutes     Int     @default(30)
  /// Day of month payroll cut-off — e.g., 25 means "calculate for the
  /// 26th of prior month through the 25th of this month".
  cutoffDay              Int     @default(25)
  /// Flat deduction per "Absent" day. Phase-2 polish may auto-derive from baseSalary/30.
  absentDeductionPerDay  Decimal @db.Decimal(12, 2)
  /// Flat deduction per "Late" attendance row (count-based, ignores duration).
  lateDeduction          Decimal @db.Decimal(12, 2)
  /// Flat deduction per "EarlyLeave" attendance row.
  earlyLeaveDeduction    Decimal @db.Decimal(12, 2)
  /// Company default scheduled work start, "HH:MM" (Asia/Bangkok). The
  /// reference time for late-arrival detection until per-employee
  /// WorkSchedules are assigned. Admin-editable via /admin/settings/attendance.
  workStartTime          String  @default("09:00")
  /// Minutes after workStartTime before a check-in is flagged "Late".
  lateGraceMinutes       Int     @default(15)
  /// Late-penalty policy (C9) — money-based, each rule independently
  /// toggleable; the "1 day" penalty reuses `absentDeductionPerDay`.
  /// "N lates in a pay period = 1 day deducted" (replaces the flat
  /// `lateDeduction` per-late charge when enabled).
  lateThreeStrikeEnabled Boolean @default(true)
  lateThreeStrikeCount   Int     @default(3)
  /// A late beyond this many minutes past the start is "severe". A severe late
  /// on a day with NO approved leave = 1 day deducted. (>30 ⇒ 09:31 when start
  /// is 09:00; a same-day leave exempts it — that deduction is handled by leave.)
  severeLateEnabled      Boolean @default(true)
  severeLateThresholdMin Int     @default(30)

  updatedAt DateTime @updatedAt
}

// ─── Cross-cutting ─────────────────────────────────────────────────────────

model Holiday {
  id           String    @id @default(uuid()) @db.Uuid
  date         DateTime  @unique @db.Date
  name         String // "วันแรงงาน"
  /// True if this is a substitute day (Thai cabinet decree, or auto-shifted
  /// because the original Mon-holiday fell on Koolman's closed day).
  isSubstitute Boolean   @default(false)
  archivedAt   DateTime?
}

model Notification {
  id        String       @id @default(uuid()) @db.Uuid
  userId    String       @db.Uuid
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel   NotifChannel
  event     String // "leave.approved", "advance.approved", "payroll.published", ...
  payload   Json
  readAt    DateTime?
  sentAt    DateTime?
  createdAt DateTime     @default(now())

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, readAt])
}

model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  /// User.id of the actor, or null for system actions / when actor deleted.
  actorId     String?  @db.Uuid
  action      String // "employee.create", "payroll.publish", "leave.approve", ...
  entityType  String // "Employee", "Payroll", "LeaveRequest", ...
  entityId    String   @db.Uuid
  beforeValue Json?
  afterValue  Json?
  metadata    Json? // IP, user-agent, source location, etc.
  createdAt   DateTime @default(now())

  @@index([entityType, entityId, createdAt(sort: Desc)])
  @@index([actorId, createdAt(sort: Desc)])
  @@index([action])
}

/// Generic machine-translation cache. Keyed by a hash of the source text +
/// target language so ANY free-text field (leave reasons, void reasons,
/// review notes, …) can be translated on demand and re-served for free.
/// Rows are immutable — a given (sourceHash, targetLang) always maps to the
/// same translation, so there is no update path and no TTL.
model Translation {
  id                 String   @id @default(uuid()) @db.Uuid
  /// sha256 hex of the normalized (trimmed) source text.
  sourceHash         String
  /// BCP-47-ish target language code, e.g. "th".
  targetLang         String
  /// Original text, stored verbatim for debugging / cache audits.
  sourceText         String
  translatedText     String
  /// Source language Google auto-detected, e.g. "my" (Burmese), "th".
  detectedSourceLang String
  createdAt          DateTime @default(now())

  @@unique([sourceHash, targetLang])
}
