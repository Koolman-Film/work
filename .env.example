# Koolman HR — environment variable template
#
# Copy to .env.local and fill in real values. .env.local is gitignored.
# For local dev convenience, real values are also kept in docs/v2/credentials.local.md (gitignored).

# ─── Supabase ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_DB_PASSWORD=
DATABASE_URL=
DATABASE_POOLER_URL=

# ─── LINE ──────────────────────────────────────────────────────────────────
# LINE Login channel (OIDC for employee LIFF auth)
NEXT_PUBLIC_LIFF_ID=
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
# LINE Messaging API channel (bot pushes for leave/advance notifications).
# This is a SEPARATE channel from the Login one, in the same Provider.
LINE_MESSAGING_CHANNEL_ID=
LINE_MESSAGING_CHANNEL_SECRET=
LINE_MESSAGING_CHANNEL_ACCESS_TOKEN=
# Admin rich menu id — created once via scripts/setup-admin-rich-menu.ts
ADMIN_RICH_MENU_ID=

# ─── Sentry (free tier) ────────────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# ─── Inngest (free tier) ───────────────────────────────────────────────────
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ─── Google Cloud Translation (admin "แปลเป็นไทย" on native-language reasons) ──
# API key for the Cloud Translation API (v2). Create in GCP console →
# APIs & Services → Credentials → "API key", then enable "Cloud Translation
# API". Server-only — never expose as NEXT_PUBLIC_. Leave blank to disable the
# translate button (it just shows "แปลไม่สำเร็จ — ลองใหม่" if clicked).
GOOGLE_TRANSLATE_API_KEY=

# ─── Runtime ───────────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000


# ─── Pairing token signing ───
PAIRING_JWT_SECRET=
