# Python (for tooling scripts)
__pycache__/
*.pyc
.venv/
venv/

# Generated artifacts (regenerable from source mockups)
docs/v1/screens/mockups/screenshots/

# Generated docx/pdf — regenerable from build script
docs/v1/Koolman_HR_Mockup_Walkthrough.docx
docs/v1/Koolman_HR_Mockup_Walkthrough.pdf

# Temp
/tmp/
*.tmp

# Next.js build artifacts
.next/
out/
# Generated by `next dev`/`next build`/`next typegen` — content differs
# between dev and build, so tracking it churns the tree forever. The
# `typecheck` script regenerates it via `next typegen` before tsc.
next-env.d.ts
next-env.d.ts.bak
*.tsbuildinfo

# Playwright artifacts
test-results/
playwright-report/
blob-report/
playwright/.cache/
.superpowers/

# MCP browser captures + ad-hoc dev screenshots (repo root only)
.playwright-mcp/
/*.png

# Supabase CLI local scaffolding (untracked dev state, not part of the project)
supabase/
